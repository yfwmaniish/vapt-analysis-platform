"""
Environment variable loader.

Create a .env file based on .env.example and populate with your keys.
"""

# Shodan API Key
SHODAN_API_KEY=
# VirusTotal API Key
VIRUSTOTAL_API_KEY=
# Have I Been Pwned API Key (optional)
HIBP_API_KEY=
# OpenRouter API Key for AI features
LLM_API_KEY=
# LLM Model (default: anthropic/claude-sonnet-4)
LLM_MODEL=anthropic/claude-sonnet-4
# Server config
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
